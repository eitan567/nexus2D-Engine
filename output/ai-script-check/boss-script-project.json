              "type": "Script",
              "enabled": true,
              "code": "export default class BossLogic {\n  constructor() {\n    this.jumpTimer = 0;\n  }\n  update(dt) {\n    this.jumpTimer += dt;\n    if (this.jumpTimer > 2.5) {\n      const rb = this.entity.getComponent('RigidBody');\n      if (rb && rb.velocity) {\n        rb.velocity.y = -500;\n      }\n      this.jumpTimer = 0;\n    }\n  }\n}"
