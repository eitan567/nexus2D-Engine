            {
              "id": "script-32rpuqnv",
              "type": "Script",
              "enabled": true,
              "code": "export default class BossScript {\n  init(entity) {\n    this.entity = entity;\n    this.speed = 150;\n    this.direction = -1;\n    this.startX = entity.transform.position.x;\n  }\n  update(dt) {\n    const rb = this.entity.getComponent('RigidBody');\n    if (rb) {\n      rb.velocity.x = this.speed * this.direction;\n    }\n    if (this.entity.transform.position.x < this.startX - 250) {\n      this.direction = 1;\n    } else if (this.entity.transform.position.x > this.startX + 250) {\n      this.direction = -1;\n    }\n  }\n}"
            }
