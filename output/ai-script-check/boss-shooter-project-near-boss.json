            {
              "id": "script-m5s5y1yd",
              "type": "Script",
              "enabled": true,
              "code": "function update(entity, dt) {\n  if (!entity.state || !entity.state.active) {\n    entity.transform.x = -500;\n    entity.transform.y = -500;\n    return;\n  }\n\n  entity.state.life = Math.max(0, entity.state.life - dt);\n  const duration = Math.max(0.001, entity.state.duration);\n  const progress = Math.min(1, Math.max(0, 1 - entity.state.life / duration));\n  entity.transform.y = entity.state.originY;\n  entity.transform.x = entity.state.startX + entity.state.direction * entity.state.distance * progress;\n\n  if (entity.state.life <= 0) {\n    entity.state = {\n      active: false,\n      direction: 0,\n      startX: -500,\n      distance: 0,\n      duration: 0.75,\n      life: 0,\n      originY: -500,\n    };\n    entity.transform.x = -500;\n    entity.transform.y = -500;\n  }\n}"
            }
          ]
