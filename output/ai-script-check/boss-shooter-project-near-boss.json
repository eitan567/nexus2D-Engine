            },
            {
              "id": "script-x5v140bl",
              "type": "Script",
              "enabled": true,
              "code": "export default class BossShooter {\n  constructor() {\n    this.cooldown = 1;\n    this.timer = 0;\n    this.lastX = null;\n    this.facing = -1;\n  }\n\n  update(dt) {\n    const currentX = this.entity.transform.x;\n    if (this.lastX !== null) {\n      const deltaX = currentX - this.lastX;\n      if (Math.abs(deltaX) > 0.5) {\n        this.facing = deltaX > 0 ? 1 : -1;\n      }\n    }\n    this.lastX = currentX;\n\n    this.timer += dt;\n    if (this.timer < this.cooldown) {\n      return;\n    }\n\n    this.timer = 0;\n    const projectile = this.scene.entities.find((candidate) => candidate.name === 'BossProjectile');\n    if (!projectile) {\n      return;\n    }\n\n    const spawnX = this.entity.transform.x + this.facing * 72;\n    const spawnY = this.entity.transform.y - 10;\n    projectile.transform.x = spawnX;\n    projectile.transform.y = spawnY;\n    projectile.state = {\n      active: true,\n      direction: this.facing,\n      startX: spawnX,\n      distance: 320,\n      duration: 0.75,\n      life: 0.75,\n      originY: spawnY,\n    };\n  }\n}"
            }
          ]
